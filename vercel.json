{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/(css|js|images|fonts|favicon.ico|robots.txt)/(.*)", "dest": "/public/$1/$2" },
    { "src": "/(.*)\\.(css|js|mjs|map|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|eot|txt|xml)", "dest": "/public/$1.$2" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
